{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentnexus.example/schemas/connectors/customer-binding.schema.json",
  "title": "Customer Binding v1",
  "description": "The customer-specific half of a connector deployment: concrete endpoints, secret REFERENCES (never inline secrets), org/resource/field mappings and customer extensions, pinned to one exact Product Pack by key, version and content digest. A product upgrade re-points the product reference; it never overwrites this binding. Inline secret material is rejected: each secret entry allows only a name and an opaque reference (`additionalProperties:false`), so a `value`/`password`/`private_key` beside a reference is a schema violation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "binding_key", "customer", "product", "endpoints", "secrets"],
  "properties": {
    "schema_version": { "const": "connector.binding/v1" },
    "binding_key": { "type": "string", "minLength": 1 },
    "customer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ref": { "type": "string" }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product_key", "version", "digest"],
      "properties": {
        "product_key": { "$ref": "#/$defs/semanticName" },
        "version": { "$ref": "#/$defs/semver" },
        "digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 }
        }
      }
    },
    "secrets": {
      "type": "array",
      "items": { "$ref": "#/$defs/secretRef" }
    },
    "org_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit", "source"],
        "properties": {
          "unit": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resource_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capability", "resource"],
        "properties": {
          "capability": { "$ref": "#/$defs/capabilityName" },
          "resource": { "type": "string", "minLength": 1 }
        }
      }
    },
    "field_mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "source"],
        "properties": {
          "field": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "extensions": { "type": "object" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "semanticName": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$" },
    "capabilityName": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$" },
    "semver": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "secretRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ref"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ref": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9+.-]*://[^\\s]+$",
          "description": "An opaque pointer into a secret store (for example secretref://vault/acme/erp), never a raw secret value."
        }
      }
    }
  }
}
